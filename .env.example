TELEGRAM_BOT_TOKEN=

# Option 1: path to a service account JSON key. OAuth client_secret is unsupported.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Option 2: the full JSON value on one line. Useful for hosted deployments.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

STATE_FILE=./data/state.json
DEFAULT_TIMEZONE=Asia/Tokyo

# Comma-separated numeric user IDs. Access is closed unless listed here.
ALLOWED_TELEGRAM_USER_IDS=
# Public mode is dangerous for a bot with write access to financial sheets.
# Enable it only deliberately.
ALLOW_PUBLIC_ACCESS=false

# Optional: enables natural-language text and Telegram voice messages.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
VOICE_MAX_SECONDS=120
