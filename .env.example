TELEGRAM_BOT_TOKEN=

# Option 1: path to a service account JSON key. OAuth client_secret is unsupported.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Option 2: the full JSON value on one line. Useful for hosted deployments.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

STATE_FILE=./data/state.json
DEFAULT_TIMEZONE=Asia/Tokyo

# Comma-separated numeric IDs. If empty, anyone who finds the bot can use it.
ALLOWED_TELEGRAM_USER_IDS=
